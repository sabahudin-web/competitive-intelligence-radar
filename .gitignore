# User business context lives only here, never in the shared repo.
radar.config.json

# Secrets
.env
.env.*

# Generated run outputs and user analysis (keep the folders via .gitkeep, ignore ALL content).
# This keeps every briefing, dossier, and dashboard (which contain the user's business data)
# out of the shared repo.
outputs/**
!outputs/**/
!outputs/**/.gitkeep

# OS / editor noise
.DS_Store
*.log
node_modules/
