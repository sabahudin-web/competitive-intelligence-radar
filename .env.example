# Copy this file to .env and fill in your real value, or export the variable in your shell.
# .env is gitignored, so your token never gets committed.

# BrightData API token. Get a free one at brightdata.com (promo code: sabahudin, for $20 in credits).
# This starts the bundled BrightData MCP server declared in .mcp.json.
BRIGHTDATA_API_TOKEN=your-brightdata-token-here

# Notion uses OAuth (no token here). You authorize it in the connector when the server first runs.

# The council (/radar-council) needs this in your Claude Code settings.json env, not in .env:
#   "env": { "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1" }
